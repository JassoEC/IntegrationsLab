# Supabase — injected automatically by the runtime, listed here for reference
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# Twilio — WhatsApp via managed service
# Found in: console.twilio.com > Account Info
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=        # format: whatsapp:+14155238886
TWILIO_WEBHOOK_URL=            # full public URL of the webhooks-whatsapp-twilio function

# Meta — WhatsApp Cloud API (direct)
# Found in: developers.facebook.com > App Dashboard > WhatsApp > Configuration
META_APP_SECRET=               # App Secret (used for signature validation)
META_VERIFY_TOKEN=             # arbitrary string you define, must match Meta dashboard config
META_PHONE_NUMBER_ID=          # WhatsApp Business phone number ID
META_ACCESS_TOKEN=             # Permanent system user token
