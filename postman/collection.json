{
  "info": {
    "name": "Automated Notification & Payment System",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "API for automating payment processing and customer notifications across WhatsApp, Stripe, and MercadoPago.\n\nThis collection covers the full API surface — no frontend needed. The same endpoints are consumed by the web dashboard (Next.js) and mobile app (React Native/Expo) in future layers.\n\n## Setup\n\n1. Set `SUPABASE_URL` and `SUPABASE_ANON_KEY` in the collection variables\n2. Run **Auth > Login** — `ACCESS_TOKEN` and `REFRESH_TOKEN` are saved automatically\n3. All protected requests pick up `ACCESS_TOKEN` from the variable"
  },
  "variable": [
    {
      "key": "SUPABASE_URL",
      "value": "https://your-project-ref.supabase.co",
      "description": "Base URL of your Supabase project."
    },
    {
      "key": "SUPABASE_ANON_KEY",
      "value": "",
      "description": "Public anon key from Supabase project settings > API."
    },
    {
      "key": "ACCESS_TOKEN",
      "value": "",
      "description": "Set automatically after a successful login."
    },
    {
      "key": "REFRESH_TOKEN",
      "value": "",
      "description": "Set automatically after a successful login."
    },
    {
      "key": "CONVERSATION_ID",
      "value": "",
      "description": "Set automatically after Send Message. Used by Get Conversation."
    },
    {
      "key": "TWILIO_AUTH_TOKEN",
      "value": "",
      "description": "Twilio auth token — same value as TWILIO_AUTH_TOKEN in supabase/functions/.env. Used by the local simulation pre-request script to compute the HMAC-SHA1 signature."
    },
    {
      "key": "TWILIO_WEBHOOK_URL",
      "value": "",
      "description": "Full webhook URL — same value as TWILIO_WEBHOOK_URL in supabase/functions/.env (e.g. https://xxxx.ngrok-free.app/functions/v1/webhooks-whatsapp-twilio). Must match exactly for signature validation to pass."
    },
    {
      "key": "SIMULATE_FROM",
      "value": "whatsapp:+521234567890",
      "description": "Phone number used as the sender in local simulations. Use the number registered in the Twilio sandbox."
    },
    {
      "key": "STRIPE_WEBHOOK_SECRET",
      "value": "",
      "description": "Stripe webhook signing secret (whsec_...). Found in Stripe Dashboard > Developers > Webhooks > your endpoint."
    },
    {
      "key": "STRIPE_SESSION_ID",
      "value": "",
      "description": "Set automatically after Create Payment. Used by the webhook simulation to reference the correct Stripe session."
    }
  ],
  "item": [
    {
      "name": "Auth",
      "description": "Headless authentication via Supabase Auth (`/auth/v1`).\n\nNo frontend required. This same auth flow is used by Postman, the Next.js dashboard, and the React Native app — the API contract is identical across all client layers.",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "url": "{{SUPABASE_URL}}/auth/v1/signup",
            "header": [
              {
                "key": "apikey",
                "value": "{{SUPABASE_ANON_KEY}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"supersecret123\"\n}"
            },
            "description": "Creates a new user.\n\nIf email confirmation is disabled in your Supabase project, the response includes an active session immediately. Otherwise, `session` will be `null` until the user confirms their email."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "",
                  "if (res.access_token) {",
                  "  pm.collectionVariables.set('ACCESS_TOKEN', res.access_token);",
                  "  pm.collectionVariables.set('REFRESH_TOKEN', res.refresh_token);",
                  "  console.log('Tokens saved from signup response.');",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{SUPABASE_URL}}/auth/v1/token?grant_type=password",
              "host": ["{{SUPABASE_URL}}"],
              "path": ["auth", "v1", "token"],
              "query": [
                {
                  "key": "grant_type",
                  "value": "password"
                }
              ]
            },
            "header": [
              {
                "key": "apikey",
                "value": "{{SUPABASE_ANON_KEY}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"supersecret123\"\n}"
            },
            "description": "Signs in with email and password.\n\nThe `ACCESS_TOKEN` and `REFRESH_TOKEN` collection variables are set automatically by the test script."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "",
                  "pm.test('Login successful', () => {",
                  "  pm.response.to.have.status(200);",
                  "  pm.expect(res.access_token).to.be.a('string');",
                  "});",
                  "",
                  "if (res.access_token) {",
                  "  pm.collectionVariables.set('ACCESS_TOKEN', res.access_token);",
                  "  pm.collectionVariables.set('REFRESH_TOKEN', res.refresh_token);",
                  "  console.log('ACCESS_TOKEN and REFRESH_TOKEN saved.');",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{SUPABASE_URL}}/auth/v1/token?grant_type=refresh_token",
              "host": ["{{SUPABASE_URL}}"],
              "path": ["auth", "v1", "token"],
              "query": [
                {
                  "key": "grant_type",
                  "value": "refresh_token"
                }
              ]
            },
            "header": [
              {
                "key": "apikey",
                "value": "{{SUPABASE_ANON_KEY}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{REFRESH_TOKEN}}\"\n}"
            },
            "description": "Renews the `access_token` using the `refresh_token`.\n\nSupabase uses rotating refresh tokens — each use issues a new `refresh_token`. The test script updates both collection variables automatically."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "",
                  "pm.test('Token refreshed', () => {",
                  "  pm.response.to.have.status(200);",
                  "  pm.expect(res.access_token).to.be.a('string');",
                  "});",
                  "",
                  "if (res.access_token) {",
                  "  pm.collectionVariables.set('ACCESS_TOKEN', res.access_token);",
                  "  pm.collectionVariables.set('REFRESH_TOKEN', res.refresh_token);",
                  "  console.log('Tokens rotated and saved.');",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Get User",
          "request": {
            "method": "GET",
            "url": "{{SUPABASE_URL}}/auth/v1/user",
            "header": [
              {
                "key": "apikey",
                "value": "{{SUPABASE_ANON_KEY}}"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{ACCESS_TOKEN}}"
              }
            ],
            "description": "Returns the authenticated user's data.\n\nUseful to verify the `ACCESS_TOKEN` is valid and to retrieve the `user.id`."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Got user data', () => {",
                  "  pm.response.to.have.status(200);",
                  "  const res = pm.response.json();",
                  "  pm.expect(res.id).to.be.a('string');",
                  "  console.log('Authenticated as:', res.email);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": "{{SUPABASE_URL}}/auth/v1/logout",
            "header": [
              {
                "key": "apikey",
                "value": "{{SUPABASE_ANON_KEY}}"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{ACCESS_TOKEN}}"
              }
            ],
            "description": "Signs out the current user. Both `access_token` and `refresh_token` are revoked server-side.\n\nReturns `204 No Content` on success."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Signed out', () => {",
                  "  pm.response.to.have.status(204);",
                  "});",
                  "",
                  "pm.collectionVariables.set('ACCESS_TOKEN', '');",
                  "pm.collectionVariables.set('REFRESH_TOKEN', '');",
                  "console.log('Tokens cleared.');"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "WhatsApp Messaging",
      "description": "Outbound messaging and conversation management.\n\nUse these endpoints to send messages to customers and inspect conversation threads. No auth header required — designed for internal/backend use.",
      "item": [
        {
          "name": "Send Message",
          "request": {
            "method": "POST",
            "url": "{{SUPABASE_URL}}/functions/v1/messages-send",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"to\": \"whatsapp:+521234567890\",\n  \"body\": \"Your payment has been confirmed. Thank you! 🎉\",\n  \"provider\": \"twilio\"\n}",
              "options": {
                "raw": { "language": "json" }
              }
            },
            "description": "Sends an outbound WhatsApp message via Twilio or Meta.\n\nOn success, the message is stored in `messages` and threaded into the contact's open conversation.\n\nReplace `to` with a number that has joined the Twilio sandbox (`whatsapp:+52...`)."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Message sent', () => {",
                  "  pm.response.to.have.status(200);",
                  "  const res = pm.response.json();",
                  "  pm.expect(res.status).to.equal('sent');",
                  "  pm.expect(res.conversation_id).to.be.a('string');",
                  "  pm.collectionVariables.set('CONVERSATION_ID', res.conversation_id);",
                  "  console.log('Conversation ID saved:', res.conversation_id);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "List Conversations",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{SUPABASE_URL}}/functions/v1/conversations-list?status=open&limit=20&offset=0",
              "host": ["{{SUPABASE_URL}}"],
              "path": ["functions", "v1", "conversations-list"],
              "query": [
                { "key": "status", "value": "open" },
                { "key": "limit", "value": "20" },
                { "key": "offset", "value": "0" }
              ]
            },
            "description": "Returns open conversations ordered by most recent message.\n\nEach item includes the contact's phone number and display name."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Conversations listed', () => {",
                  "  pm.response.to.have.status(200);",
                  "  const res = pm.response.json();",
                  "  pm.expect(res.data).to.be.an('array');",
                  "  console.log('Total conversations:', res.count);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Conversation",
          "request": {
            "method": "GET",
            "url": "{{SUPABASE_URL}}/functions/v1/conversations-get/{{CONVERSATION_ID}}",
            "description": "Returns a single conversation with its full message thread and contact info.\n\n`CONVERSATION_ID` is set automatically after running **Send Message**. You can also copy any ID from the List Conversations response."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Conversation retrieved', () => {",
                  "  pm.response.to.have.status(200);",
                  "  const res = pm.response.json();",
                  "  pm.expect(res.messages).to.be.an('array');",
                  "  console.log('Messages in thread:', res.messages.length);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "WhatsApp Webhooks",
      "description": "Simulate inbound WhatsApp messages from each provider.\n\nThese requests replicate what Twilio and Meta send to the webhook endpoints. Signature validation is bypassed locally via `--no-verify-jwt` — in production, the provider signature headers are required.",
      "item": [
        {
          "name": "Twilio — Simulate inbound message",
          "request": {
            "method": "POST",
            "url": "{{SUPABASE_URL}}/functions/v1/webhooks-whatsapp-twilio",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              },
              {
                "key": "X-Twilio-Signature",
                "value": "local-bypass",
                "description": "In production this must be a valid HMAC-SHA1 signature computed by Twilio."
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "From", "value": "whatsapp:+521234567890" },
                { "key": "To", "value": "whatsapp:+14155238886" },
                { "key": "Body", "value": "Hello from Twilio sandbox!" },
                { "key": "MessageSid", "value": "SM00000000000000000000000000000001" },
                { "key": "NumMedia", "value": "0" }
              ]
            },
            "description": "Simulates a Twilio inbound WhatsApp message.\n\nLocally, signature validation will fail unless `TWILIO_AUTH_TOKEN` is empty or the function is deployed with `--no-verify-jwt`. For a full end-to-end test, use the Twilio sandbox and point the webhook URL to a tunnel (e.g. ngrok)."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Webhook accepted', () => {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 401]);",
                  "  if (pm.response.code === 401) {",
                  "    console.warn('Signature validation active — set TWILIO_AUTH_TOKEN in .env or use a real Twilio request.');",
                  "  }",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Meta — Verify webhook (GET challenge)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{SUPABASE_URL}}/functions/v1/webhooks-whatsapp-meta?hub.mode=subscribe&hub.verify_token=local_verify_token&hub.challenge=challenge_abc123",
              "host": ["{{SUPABASE_URL}}"],
              "path": ["functions", "v1", "webhooks-whatsapp-meta"],
              "query": [
                { "key": "hub.mode", "value": "subscribe" },
                { "key": "hub.verify_token", "value": "local_verify_token", "description": "Must match META_VERIFY_TOKEN in .env" },
                { "key": "hub.challenge", "value": "challenge_abc123" }
              ]
            },
            "description": "Simulates the one-time GET request Meta sends to verify the webhook URL.\n\nIf `hub.verify_token` matches `META_VERIFY_TOKEN` in your `.env`, the response body will be the `hub.challenge` value."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Challenge returned', () => {",
                  "  pm.response.to.have.status(200);",
                  "  pm.expect(pm.response.text()).to.equal('challenge_abc123');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Twilio — Simulate inbound (local, no Twilio quota)",
          "request": {
            "method": "POST",
            "url": "{{SUPABASE_URL}}/functions/v1/webhooks-whatsapp-twilio",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              },
              {
                "key": "X-Twilio-Signature",
                "value": "{{_twilio_sig}}",
                "description": "Computed by the pre-request script using HMAC-SHA1 over TWILIO_WEBHOOK_URL + sorted params."
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "From", "value": "{{_sim_from}}", "description": "Resolved from SIMULATE_FROM collection variable" },
                { "key": "To", "value": "{{_sim_to}}" },
                { "key": "Body", "value": "{{_sim_body}}", "description": "Random body that does not match any auto-reply trigger" },
                { "key": "MessageSid", "value": "{{_sim_sid}}", "description": "Unique SID generated per run to avoid duplicate key errors" },
                { "key": "NumMedia", "value": "0" }
              ]
            },
            "description": "Simulates a Twilio inbound message directly against the local Supabase edge function — no real Twilio call, no quota spent.\n\nThe pre-request script computes the correct HMAC-SHA1 signature so the webhook passes validation. The message body is randomised per run so it never matches an auto-reply trigger (no outbound Twilio call either).\n\n**Before running:**\n1. Set `TWILIO_AUTH_TOKEN` in collection variables (same value as in `supabase/functions/.env`)\n2. Set `TWILIO_WEBHOOK_URL` to your current ngrok URL (same as in `.env`)\n3. Optionally change `SIMULATE_FROM` to the sandbox number you joined with\n4. Make sure the edge function is running locally (`supabase start`)"
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// ── Collect inputs ────────────────────────────────────────────────────",
                  "const authToken  = pm.collectionVariables.get('TWILIO_AUTH_TOKEN');",
                  "const webhookUrl = pm.collectionVariables.get('TWILIO_WEBHOOK_URL');",
                  "const from       = pm.collectionVariables.get('SIMULATE_FROM') || 'whatsapp:+521234567890';",
                  "const to         = 'whatsapp:+14155238886';",
                  "",
                  "if (!authToken)  { throw new Error('Set TWILIO_AUTH_TOKEN in collection variables'); }",
                  "if (!webhookUrl) { throw new Error('Set TWILIO_WEBHOOK_URL in collection variables'); }",
                  "",
                  "// ── Build unique, non-triggering body ────────────────────────────────",
                  "// Prefix 'local-test-' ensures it matches no auto-reply pattern.",
                  "const body = 'local-test-' + Date.now();",
                  "const sid  = 'SMtest' + Date.now();",
                  "",
                  "// ── Expose to request body via request-scoped variables ───────────────",
                  "pm.variables.set('_sim_from', from);",
                  "pm.variables.set('_sim_to',   to);",
                  "pm.variables.set('_sim_body', body);",
                  "pm.variables.set('_sim_sid',  sid);",
                  "",
                  "// ── Compute Twilio HMAC-SHA1 signature ───────────────────────────────",
                  "// Algorithm: webhookUrl + alphabetically sorted param name+value pairs.",
                  "const params = { Body: body, From: from, MessageSid: sid, NumMedia: '0', To: to };",
                  "let sigStr = webhookUrl;",
                  "Object.keys(params).sort().forEach(k => { sigStr += k + params[k]; });",
                  "",
                  "const hash = CryptoJS.HmacSHA1(sigStr, authToken);",
                  "pm.variables.set('_twilio_sig', CryptoJS.enc.Base64.stringify(hash));",
                  "",
                  "console.log('Signature computed for URL:', webhookUrl);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Webhook accepted (200 = processed, 401 = wrong token/url)', () => {",
                  "  if (pm.response.code === 401) {",
                  "    console.error('Signature mismatch — verify TWILIO_AUTH_TOKEN and TWILIO_WEBHOOK_URL match supabase/functions/.env exactly.');",
                  "  }",
                  "  pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Meta — Simulate inbound message",
          "request": {
            "method": "POST",
            "url": "{{SUPABASE_URL}}/functions/v1/webhooks-whatsapp-meta",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Hub-Signature-256",
                "value": "sha256=local-bypass",
                "description": "In production this must be a valid HMAC-SHA256 signature computed by Meta."
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"object\": \"whatsapp_business_account\",\n  \"entry\": [\n    {\n      \"changes\": [\n        {\n          \"value\": {\n            \"messages\": [\n              {\n                \"from\": \"521234567890\",\n                \"id\": \"wamid.00000000000000000000000000000001\",\n                \"type\": \"text\",\n                \"text\": {\n                  \"body\": \"Hello from Meta!\"\n                }\n              }\n            ],\n            \"metadata\": {\n              \"phone_number_id\": \"123456789\"\n            }\n          }\n        }\n      ]\n    }\n  ]\n}"
            },
            "description": "Simulates a Meta Cloud API inbound WhatsApp message.\n\nLocally, signature validation will fail unless `META_APP_SECRET` is empty. For a full end-to-end test, point the Meta webhook URL to a tunnel (e.g. ngrok) with a verified Meta App."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Webhook accepted', () => {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 401]);",
                  "  if (pm.response.code === 401) {",
                  "    console.warn('Signature validation active — set META_APP_SECRET in .env or use a real Meta request.');",
                  "  }",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Stripe Payments",
      "description": "Create Stripe Checkout Sessions and simulate the payment webhook.\n\n**Flow:**\n1. Run **Create Payment** → copy the `payment_url` and open it in the browser\n2. Complete payment with Stripe test card `4242 4242 4242 4242`\n3. Stripe fires the webhook automatically — or use **Simulate Webhook** to trigger it locally without going through the browser",
      "item": [
        {
          "name": "Create Payment",
          "request": {
            "method": "POST",
            "url": "{{SUPABASE_URL}}/functions/v1/payments-create",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 20.00,\n  \"currency\": \"usd\",\n  \"customer_phone\": \"+521234567890\",\n  \"description\": \"Order #1001 — Pro Plan\"\n}",
              "options": {
                "raw": { "language": "json" }
              }
            },
            "description": "Creates a Stripe Checkout Session and stores a `pending` payment record.\n\nReturns a `payment_url` — open it in the browser to complete the payment with Stripe test card `4242 4242 4242 4242`.\n\nThe `customer_phone` is saved in the payment metadata and used by the webhook handler to send a WhatsApp confirmation on success.\n\nThe `STRIPE_SESSION_ID` collection variable is set automatically by the test script for use in the webhook simulation."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Payment created', () => {",
                  "  pm.response.to.have.status(201);",
                  "  const res = pm.response.json();",
                  "  pm.expect(res.payment_url).to.be.a('string');",
                  "  pm.expect(res.external_id).to.be.a('string');",
                  "  pm.collectionVariables.set('STRIPE_SESSION_ID', res.external_id);",
                  "  console.log('Session ID saved:', res.external_id);",
                  "  console.log('Payment URL:', res.payment_url);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Simulate Webhook — checkout.session.completed",
          "request": {
            "method": "POST",
            "url": "{{SUPABASE_URL}}/functions/v1/webhooks-stripe",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Stripe-Signature",
                "value": "{{_stripe_sig}}",
                "description": "Computed by the pre-request script using HMAC-SHA256 over timestamp + body."
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{{_stripe_body}}",
              "options": {
                "raw": { "language": "json" }
              }
            },
            "description": "Simulates a `checkout.session.completed` Stripe event directly against the local edge function — no real Stripe call needed.\n\nThe pre-request script:\n1. Reads `STRIPE_SESSION_ID` (set automatically by Create Payment)\n2. Builds a realistic Stripe event payload\n3. Computes the `Stripe-Signature` header (HMAC-SHA256, same algorithm as production)\n\n**Before running:**\n1. Set `STRIPE_WEBHOOK_SECRET` in collection variables (same value as in `supabase/functions/.env`)\n2. Run **Create Payment** first so `STRIPE_SESSION_ID` is populated — or paste a session ID manually"
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// ── Collect inputs ────────────────────────────────────────────────────",
                  "const secret    = pm.collectionVariables.get('STRIPE_WEBHOOK_SECRET');",
                  "const sessionId = pm.collectionVariables.get('STRIPE_SESSION_ID') || 'cs_test_placeholder';",
                  "",
                  "if (!secret) { throw new Error('Set STRIPE_WEBHOOK_SECRET in collection variables'); }",
                  "",
                  "// ── Build event payload ───────────────────────────────────────────────",
                  "const timestamp = Math.floor(Date.now() / 1000);",
                  "const event = {",
                  "  id: 'evt_test_' + Date.now(),",
                  "  type: 'checkout.session.completed',",
                  "  data: {",
                  "    object: {",
                  "      id: sessionId,",
                  "      payment_status: 'paid',",
                  "      amount_total: 2000,",
                  "      currency: 'usd'",
                  "    }",
                  "  }",
                  "};",
                  "",
                  "const body = JSON.stringify(event);",
                  "",
                  "// ── Compute Stripe HMAC-SHA256 signature ─────────────────────────────",
                  "// Algorithm: HMAC-SHA256 of '<timestamp>.<rawBody>' using webhook secret.",
                  "const payload = timestamp + '.' + body;",
                  "const hash = CryptoJS.HmacSHA256(payload, secret);",
                  "const sigHex = CryptoJS.enc.Hex.stringify(hash);",
                  "",
                  "pm.variables.set('_stripe_sig',  't=' + timestamp + ',v1=' + sigHex);",
                  "pm.variables.set('_stripe_body', body);",
                  "",
                  "console.log('Stripe signature computed for session:', sessionId);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Webhook processed (200)', () => {",
                  "  if (pm.response.code === 401) {",
                  "    console.error('Signature mismatch — verify STRIPE_WEBHOOK_SECRET matches supabase/functions/.env exactly.');",
                  "  }",
                  "  pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}
